{
  "id": "graphql-query_50_0001_err_graphql_query_query_and_file_json",
  "description": "graphql-query rejects --query and --file together",
  "command": "graphql-query",
  "args": [
    "--workspace",
    "${WORKSPACE}",
    "--schema",
    "${SCHEMA}",
    "graphql-query",
    "--query",
    "query { feature { items { id slug } totalCount } }",
    "--file",
    "${CASE}/query.graphql"
  ],
  "expect": {
    "exit_code": 2,
    "response_file": "response.json"
  },
  "workspace": {
    "input_dir": "workspace.in",
    "output_dir": "workspace.out",
    "assert_output": false
  }
}
