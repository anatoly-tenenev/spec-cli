{
  "id": "graphql-query_50_0003_err_graphql_query_require_abs_relative_file_json",
  "description": "graphql-query rejects relative --file under --require-absolute-paths",
  "command": "graphql-query",
  "args": [
    "--require-absolute-paths",
    "--workspace",
    "${WORKSPACE}",
    "--schema",
    "${SCHEMA}",
    "graphql-query",
    "--file",
    "query.graphql"
  ],
  "expect": {
    "exit_code": 2,
    "response_file": "response.json"
  },
  "workspace": {
    "input_dir": "workspace.in",
    "output_dir": "workspace.out",
    "assert_output": false
  }
}
