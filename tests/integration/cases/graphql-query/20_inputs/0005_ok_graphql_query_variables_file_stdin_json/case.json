{
  "id": "graphql-query_20_0005_ok_graphql_query_variables_file_stdin_json",
  "description": "graphql-query reads variables from stdin when --variables-file is -",
  "command": "graphql-query",
  "args": [
    "--workspace",
    "${WORKSPACE}",
    "--schema",
    "${SCHEMA}",
    "graphql-query",
    "--file",
    "${CASE}/query.graphql",
    "--variables-file",
    "-"
  ],
  "expect": {
    "exit_code": 0,
    "response_file": "response.json"
  },
  "workspace": {
    "input_dir": "workspace.in",
    "output_dir": "workspace.out",
    "assert_output": false
  },
  "runtime": {
    "stdin_file": "variables.json"
  }
}
